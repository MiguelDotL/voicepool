# Voicepool Environment Configuration

# AES-256-GCM encryption key for API keys at rest.
# Must be exactly 32 bytes (64 hex characters).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# Backend port (default: 3500)
PORT=3500

# --- Optional: Email automation for ElevenLabs signups ---
# Catch-all domain that Voicepool generates signup emails on (e.g. yourdomain.com).
# Leave unset to disable the Enroll panel.
MAIL_DOMAIN=

# IMAP credentials for the inbox the catch-all forwards to.
# For Gmail, enable 2FA and create an app password at https://myaccount.google.com/apppasswords
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# --- Optional: Full ElevenLabs signup automation (Playwright) ---
# Requires: EL_AUTOMATION_ENABLED=true, EL_SHARED_PASSWORD set, and a one-time
# `npx playwright install chromium` from inside the api/ directory.
EL_AUTOMATION_ENABLED=false

# Password used for every auto-generated EL account (free accounts only).
# Stored encrypted per-row in the DB. Min 8 chars, mix of letters/numbers.
EL_SHARED_PASSWORD=

# Comma-separated voice names to auto-add to each new account.
EL_DEFAULT_VOICES=Declan Sage
